PORT=3000
MCP_AUTH_TOKEN=
INTERVALS_ICU_API_KEY=
INTERVALS_ICU_ATHLETE_ID=
USER_TIMEZONE=Europe/Warsaw
# Local development: point at a private file that is not committed to Git.
TRAINING_PROFILE_PATH=./config/training-profile.yaml
# Railway: set the full profile as a multiline variable. It takes precedence
# over TRAINING_PROFILE_PATH when both variables are configured.
# TRAINING_PROFILE_YAML=
WRITE_ENABLED=false
VALIDATION_HMAC_SECRET=
LOG_LEVEL=info

# Optional advanced settings
# INTERVALS_ICU_BASE_URL=https://intervals.icu/api/v1
# INTERVALS_ICU_TIMEOUT_MS=10000
