{
  "name": "intervals-icu-mcp",
  "version": "3.0.0",
  "description": "MCP server for the intervals.icu API - analyze training history and plan/schedule workouts.",
  "main": "dist/index.js",
  "bin": {
    "intervals-icu-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --project tsconfig.test.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "knip": "knip",
    "architecture": "depcruise src",
    "check": "npm run typecheck && npm run typecheck:test && npm run lint && npm run test && npm run architecture && npm run knip"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "luxon": "^3.7.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^10.6.0",
    "knip": "^6.26.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
